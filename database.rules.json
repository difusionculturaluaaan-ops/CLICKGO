{
  "rules": {
    "usuarios": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$userId": {
        ".read": "auth != null"
      }
    },
    "rutas": {
      ".read": "auth != null",
      "$rutaId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "ubicaciones": {
      "$rutaId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "presencia": {
      "$orgId": {
        ".read": "auth != null",
        "$rutaId": {
          "$paradaId": {
            ".write": "auth != null"
          }
        }
      }
    },
    "esperando": {
      "$paradaId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "historial": {
      "$orgId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "organizaciones": {
      ".read": "auth != null"
    },
    "preregistros": {
      "$orgId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
