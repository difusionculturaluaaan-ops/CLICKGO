{
  "rules": {
    "usuarios": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$userId": {
        ".read": "auth != null"
      }
    },
    "rutas": {
      ".read": "auth != null",
      "$rutaId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "ubicaciones": {
      ".read": "auth != null",
      "$rutaId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "presencia": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
        }
      }
    },
    "esperando": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    },
    "historial": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    },
    "organizaciones": {
      ".read": "auth != null"
    },
    "preregistros": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    },
    "trail": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    },
    "unidades": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    }
  }
}
