{
  "rules": {
    "usuarios": {
      ".read": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'superadmin'",
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || root.child('usuarios').child(auth.uid).child('orgId').val() === root.child('usuarios').child($userId).child('orgId').val())",
        ".write": "auth != null && auth.uid === $userId"
      }
    },
    "rutas": {
      ".read": "auth != null",
      "$rutaId": {
        ".write": "auth != null && (newData.exists() ? newData.child('orgId').val() : data.child('orgId').val()) === root.child('usuarios').child(auth.uid).child('orgId').val()"
      }
    },
    "ubicaciones": {
      ".read": "auth != null",
      "$rutaId": {
        ".write": "auth != null && root.child('rutas').child($rutaId).child('orgId').val() === root.child('usuarios').child(auth.uid).child('orgId').val()"
      }
    },
    "presencia": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
        }
      }
    },
    "esperando": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    },
    "historial": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    },
    "organizaciones": {
      ".read": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'superadmin'",
      ".write": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'superadmin'",
      "$orgId": {
        ".read": "auth != null && (root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId || root.child('usuarios').child(auth.uid).child('rol').val() === 'superadmin')"
      }
    },
    "preregistros": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    },
    "trail": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    },
    "unidades": {
      "$orgId": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('orgId').val() === $orgId"
      }
    }
  }
}
