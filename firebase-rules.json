{
  "rules": {
    "ubicaciones": {
      ".read": true,
      "$rutaId": {
        ".write": "auth != null && (root.child('usuarios/' + auth.uid + '/rol').val() === 'chofer' || root.child('usuarios/' + auth.uid + '/rol').val() === 'admin')"
      }
    },

    "organizaciones": {
      "$orgId": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('usuarios/' + auth.uid + '/rol').val() === 'admin' && root.child('usuarios/' + auth.uid + '/orgId').val() === $orgId"
      }
    },

    "rutas": {
      ".read": "auth != null",
      "$rutaId": {
        ".write": "auth != null && (root.child('usuarios/' + auth.uid + '/rol').val() === 'admin' || root.child('usuarios/' + auth.uid + '/rol').val() === 'chofer')"
      }
    },

    "usuarios": {
      ".read": "auth != null && root.child('usuarios/' + auth.uid + '/rol').val() === 'admin'",
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || root.child('usuarios/' + auth.uid + '/rol').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $userId || root.child('usuarios/' + auth.uid + '/rol').val() === 'admin')"
      }
    },

    "historial": {
      ".read": "auth != null",
      "$orgId": {
        ".write": "auth != null && root.child('usuarios/' + auth.uid + '/rol').val() === 'admin'"
      }
    },

    "presencia": {
      ".read": "auth != null",
      "$orgId": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "esperando": {
      ".read": "auth != null",
      "$orgId": {
        "$paradaId": {
          "$hash": {
            ".write": "auth != null"
          }
        }
      }
    }
  }
}
